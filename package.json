{
  "name": "gdje-i-kada-native",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:test": "node ./scripts/with-env.js test npx expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "postinstall": "node ./scripts/patch-react-native-maps-airmap.js",
    "android": "expo run:android --variant prodDebug",
    "android:test": "node ./scripts/with-env.js test npx expo run:android --variant qaDebug",
    "build:android:test": "node ./scripts/with-env.js test ./android/gradlew -p android :app:assembleQaRelease",
    "build:android:test:eas": "npx eas-cli build --platform android --profile test",
    "ios": "node ./scripts/run-ios.js",
    "ios:dev": "node ./scripts/run-ios.js",
    "ios:test": "node ./scripts/with-env.js test node ./scripts/run-ios.js --device",
    "ios:test:release": "node ./scripts/with-env.js test node ./scripts/run-ios.js --device --configuration Release",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "TZ=UTC jest --runInBand"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "supercluster": "^8.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@types/supercluster": "^7.1.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
